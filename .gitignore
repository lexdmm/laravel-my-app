# Ambiente
.env
.env.backup
.env.production
*.key

# Dependências
/vendor
/node_modules

# Build
/public/build
/public/hot
/public/storage

# Bootstrap cache
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

# Storage — app uploads
/storage/app/private/*
!/storage/app/private/.gitkeep
/storage/app/public/*
!/storage/app/public/.gitkeep

# Storage — framework (arquivos gerados pelo Laravel)
/storage/framework/compiled.php
/storage/framework/config.php
/storage/framework/down
/storage/framework/events.scanned.php
/storage/framework/maintenance.php
/storage/framework/routes.php
/storage/framework/routes.scanned.php
/storage/framework/schedule-*
/storage/framework/services.json
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/testing/*
!/storage/framework/testing/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep

# Logs
/storage/logs/*
!/storage/logs/.gitkeep

# Banco SQLite (desenvolvimento local)
/database/*.sqlite*

# IDEs e editores
/.idea
/.vscode
/.cursor/
/.zed
/.nova
/.codex
.DS_Store
Thumbs.db
.phpactor.json

# Laravel / PHP misc
/auth.json
/storage/pail
/public/fonts-manifest.dev.json
_ide_helper.php
